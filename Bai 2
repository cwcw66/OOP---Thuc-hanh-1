

#include <iostream>
using namespace std;

 
class DIEM {
   private:
    int x, y;
   public:
    void input ();
    void output ();
    double tinhkhoangcach (DIEM &p);
};
void DIEM::input (){
    cin >> x >> y ;
}

double DIEM::tinhkhoangcach(DIEM & p1){
    return sqrt(((x-p1.x)*(x-p1.x)) + ((y-p1.y)*(y-p1.y)));
}
void DIEM::output(){
    cout << "(" << x << ", " << y << ")"; 
    cout << endl;
}




int main (){
    DIEM p1, p2;
    cout << "Nhap diem thu nhat: ";
    p1.input();
    cout << "Toa do diem thu nhat la: ";
    p1.output();
    cout << "Nhap diem thu hai: ";
    p2.input();
    cout << "Toa do diem hu hai la: ";
    p2.output();
    double kc = p1.tinhkhoangcach(p2);
    cout << "Khoang cach giua hai diem la: " << kc << endl;
    
    return 0;
}


